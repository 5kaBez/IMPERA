generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institute {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  shortName  String?
  directions Direction[]
  createdAt  DateTime    @default(now())
}

model Direction {
  id          Int       @id @default(autoincrement())
  name        String
  instituteId Int
  institute   Institute @relation(fields: [instituteId], references: [id], onDelete: Cascade)
  programs    Program[]
  createdAt   DateTime  @default(now())

  @@unique([name, instituteId])
}

model Program {
  id          Int       @id @default(autoincrement())
  name        String
  directionId Int
  direction   Direction @relation(fields: [directionId], references: [id], onDelete: Cascade)
  groups      Group[]
  createdAt   DateTime  @default(now())

  @@unique([name, directionId])
}

model Group {
  id             Int      @id @default(autoincrement())
  name           String
  number         Int
  course         Int
  studyForm      String   @default("Очная")
  educationLevel String   @default("Бакалавриат")
  programId      Int
  program        Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  lessons        Lesson[]
  users          User[]
  notes          Note[]
  createdAt      DateTime @default(now())

  @@unique([number, programId, course, studyForm])
}

model Lesson {
  id         Int      @id @default(autoincrement())
  groupId    Int
  group      Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  dayOfWeek  Int // 1=Пн, 2=Вт, 3=Ср, 4=Чт, 5=Пт, 6=Сб
  pairNumber Int
  timeStart  String
  timeEnd    String
  parity     Int // 0=чёт, 1=нечёт, 2=обе
  subject    String
  lessonType String // Лекция, Практика, Лабораторная, ПЗ
  teacher    String
  room       String
  weekStart  Int      @default(1)
  weekEnd    Int      @default(18)
  notes      Note[]
  createdAt  DateTime @default(now())

  @@index([groupId, dayOfWeek])
  @@index([groupId, dayOfWeek, parity])
}

model User {
  id                  Int               @id @default(autoincrement())
  telegramId          String            @unique
  firstName           String
  lastName            String?
  username            String?
  photoUrl            String?
  groupId             Int?
  group               Group?            @relation(fields: [groupId], references: [id])
  role                String            @default("student") // student, admin
  notifyBefore        Boolean           @default(true)
  notifyChanges       Boolean           @default(true)
  referralCode        String?           @unique // персональный реферальный код (8-char hex)
  referredBy          String? // код того, кто пригласил
  referralCount       Int               @default(0) // сколько людей пригласил
  activated           Boolean           @default(true) // false = нужен инвайт-код для доступа
  banned              Boolean           @default(false) // заблокированный пользователь
  avatarId            Int               @default(0) // 0 = буква, 1-8 = аватарки Даши
  lastCodeGeneration  DateTime? // Время последней генерации инвайт-кода
  codesGeneratedTotal Int               @default(0) // Общий счётчик созданных кодов
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  feedbacks           Feedback[]
  reviews             Review[]
  notes               Note[]
  sportFavorites      SportFavorite[]
  sportEnrollments    SportEnrollment[] // На какую секцию записан
  sportTeaching       SportTeacher[] // Секции, где юзер — преподаватель физры
  sportSessions       SportSession[]    @relation("SessionTeacher")
  sportAttendances    SportAttendance[] @relation("AttendanceStudent")
  codesCreated        InviteCode[]      @relation("CodeCreator")
  codesUsed           InviteCode[]      @relation("CodeUsedBy")
  // Analytics
  sessions            UserSession[]     @relation("Sessions")
  events              Event[]           @relation("Events")
  pageViews           PageView[]        @relation("PageViews")
  searches            Search[]          @relation("Searches")
  filters             Filter[]          @relation("Filters")
  clientErrors        ClientError[]     @relation("ClientErrors")
  featureUsages       FeatureUsage[]    @relation("FeatureUsages")
  performanceMetrics  PerformanceMetric[] @relation("PerformanceMetrics")
  contentInteractions ContentInteraction[] @relation("ContentInteractions")
  subscriptions       Subscription[]    @relation("Subscriptions")
  recommendations     Recommendation[]  @relation("Recommendations")
  buttonClicks        ButtonClick[]     @relation("ButtonClicks")
  metricsSnapshots    UserMetricsSnapshot[] @relation("MetricsSnapshots")
}

model Feedback {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @default("suggestion") // suggestion, complaint, bug, other
  message   String
  status    String   @default("new") // new, read, resolved
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Teacher {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  department String?
  photoUrl   String?
  reviews    Review[]
  createdAt  DateTime @default(now())
}

model Review {
  id        Int      @id @default(autoincrement())
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1-5
  text      String?
  anonymous Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([teacherId, userId])
  @@index([teacherId])
}

// ===== Физкультура =====
model SportSection {
  id          Int               @id @default(autoincrement())
  name        String            @unique // Атлетизм, Аэробика, Баскетбол, etc.
  emoji       String? // 🏋️, 💃, 🏀, etc.
  geoLat      Float? // Координаты зала для гео-проверки
  geoLon      Float?
  slots       SportSlot[]
  favorites   SportFavorite[]
  enrollments SportEnrollment[]
  teachers    SportTeacher[]
  sessions    SportSession[]
  createdAt   DateTime          @default(now())
}

model SportSlot {
  id        Int            @id @default(autoincrement())
  sectionId Int
  section   SportSection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 1=Пн, 2=Вт, 3=Ср, 4=Чт, 5=Пт, 6=Сб
  timeStart String // "09:00"
  timeEnd   String // "10:30"
  teacher   String
  location  String? // Спортзал, Бассейн, etc.
  capacity  Int? // Максимум студентов (опционально)
  sessions  SportSession[]
  createdAt DateTime       @default(now())

  @@unique([sectionId, dayOfWeek, timeStart])
  @@index([sectionId, dayOfWeek])
}

model SportFavorite {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionId Int
  section   SportSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, sectionId])
}

// Запись студента на секцию (enrollment) — одна активная секция
model SportEnrollment {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionId Int
  section   SportSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, sectionId])
}

// ===== Антифрод-система посещений =====

// Связь «преподаватель физры ↔ секция» (один юзер может вести несколько секций)
model SportTeacher {
  id        Int          @id @default(autoincrement())
  userId    Int
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionId Int
  section   SportSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@unique([userId, sectionId])
}

// Сессия занятия — преподаватель «открывает пару»
model SportSession {
  id          Int               @id @default(autoincrement())
  sectionId   Int
  section     SportSection      @relation(fields: [sectionId], references: [id])
  slotId      Int?
  slot        SportSlot?        @relation(fields: [slotId], references: [id])
  teacherId   Int
  teacher     User              @relation("SessionTeacher", fields: [teacherId], references: [id])
  status      String            @default("active") // active, completed, cancelled
  secretSeed  String? // Секрет (legacy TOTP, теперь опционально)
  startedAt   DateTime          @default(now())
  endedAt     DateTime?
  attendances SportAttendance[]

  @@index([status, startedAt])
  @@index([teacherId])
}

// Посещение студента с хеш-цепочкой + гео + отпечаток устройства
model SportAttendance {
  id          Int          @id @default(autoincrement())
  sessionId   Int
  session     SportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   Int
  student     User         @relation("AttendanceStudent", fields: [studentId], references: [id])
  status      String       @default("pending") // pending → confirmed / rejected
  geoLat      Float? // Откуда отметился студент
  geoLon      Float?
  geoDistM    Int? // Расстояние до зала (метры)
  geoOk       Boolean      @default(false) // <= 1км
  deviceHash  String? // Отпечаток устройства (1 телефон = 1 студент)
  checkedInAt DateTime     @default(now())
  confirmedAt DateTime?
  hash        String // SHA256(studentId:sessionId:timestamp:prevHash)
  prevHash    String? // Хеш предыдущей записи этого студента

  @@unique([sessionId, studentId]) // Один студент — одна отметка за сессию
  @@index([studentId, checkedInAt])
}

// ===== Заметки / Домашка =====
model Note {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    Int?
  lesson      Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  date        DateTime
  title       String
  text        String?
  notifyAt    DateTime?
  notified    Boolean   @default(false)
  authorRole  String    @default("student") // student | teacher
  groupId     Int?
  group       Group?    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
  @@index([lessonId])
  @@index([groupId, date])
  @@index([notifyAt, notified])
}

// ===== История импорта расписания =====
model ScheduleImport {
  id           Int       @id @default(autoincrement())
  status       String    @default("running") // running, success, error
  importedRows Int       @default(0)
  skippedRows  Int       @default(0)
  institutes   Int       @default(0)
  directions   Int       @default(0)
  programs     Int       @default(0)
  groups       Int       @default(0)
  source       String    @default("manual") // manual, auto
  error        String?
  filePath     String? // путь к сохранённому xlsx
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
}

// ===== Резервные копии БД =====
model Backup {
  id            Int      @id @default(autoincrement())
  name          String   @unique // Имя файла бекапа (e.g., "backup-2026-03-12-15-30.sql")
  fileSize      Int // Размер файла в байтах
  userCount     Int? // Мгновенный снимок: кол-во юзеров при создании
  groupCount    Int? // Кол-во групп при создании
  lessonCount   Int? // Кол-во уроков при создании
  source        String   @default("manual") // manual, auto
  filePath      String // Полный путь к файлу на диске
  restoredCount Int      @default(0) // Сколько раз был восстановлен
  createdAt     DateTime @default(now())
}

// ===== Инвайт-коды для вирусной механики приглашений =====
model InviteCode {
  id        Int       @id @default(autoincrement())
  code      String    @unique // 8-символьная уникальная строка
  creatorId Int
  creator   User      @relation("CodeCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  usedById  Int? // telegramId или id того, кто использовал
  usedBy    User?     @relation("CodeUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  usedAt    DateTime?

  @@index([creatorId])
  @@index([usedById])
  @@index([createdAt])
}

// ===== АНАЛИТИКА И МЕТРИКИ =====

// Сессии пользователей — отслеживание времени в приложении
model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("Sessions", fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique // UUID для отслеживания сессии
  platform     String   @default("web") // web, mobile, telegram
  userAgent    String?
  ipAddress    String?
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  durationSec  Int? // Длительность сессии в секундах
  pageViews    Int      @default(0) // Количество просмотров страниц в сессии
  events       Int      @default(0) // Количество событий в сессии
  sessionEvents  Event[]        @relation("SessionEvents")
  sessionPageViews PageView[]   @relation("SessionPageViews")
  
  @@index([userId])
  @@index([startedAt])
}

// Отслеживание пользовательских событий (клики, навигация, действия)
model Event {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("Events", fields: [userId], references: [id], onDelete: Cascade)
  sessionId Int?
  session   UserSession? @relation("SessionEvents", fields: [sessionId], references: [id], onDelete: SetNull)
  eventType String   // button_click, page_view, form_submit, search, filter_apply, etc.
  eventName String   // Название события (e.g., "submit_feedback", "join_sport_section")
  category  String?  // Категория события (schedule, profile, sports, feedback, etc.)
  value     Int?     // Числовое значение (e.g., количество результатов поиска)
  metadata  String?  // JSON с дополнительными данными
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([timestamp])
  @@index([sessionId])
  @@index([eventName])
}

// Просмотры страниц
model PageView {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("PageViews", fields: [userId], references: [id], onDelete: Cascade)
  sessionId Int?
  session   UserSession? @relation("SessionPageViews", fields: [sessionId], references: [id], onDelete: SetNull)
  page      String   // /schedule, /profile, /sports, /feedback, /admin, etc.
  referrer  String?  // Откуда пришел пользователь
  timeOnPage Int?    // Время на странице в секундах
  viewedAt  DateTime @default(now())

  @@index([userId])
  @@index([page])
  @@index([viewedAt])
}

// Поиск — отслеживание того, что ищут пользователи
model Search {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("Searches", fields: [userId], references: [id], onDelete: Cascade)
  searchType String  // schedule, teachers, sports, etc.
  query     String   // Поисковый запрос
  resultCount Int?   // Количество результатов
  hasClicked Boolean @default(false) // Нажал ли на результат
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([searchType])
  @@index([timestamp])
}

// Фильтры — какие фильтры применяют пользователи
model Filter {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("Filters", fields: [userId], references: [id], onDelete: Cascade)
  page      String   // Страница, где применили фильтр
  filterType String  // institute, direction, program, day_of_week, etc.
  filterValue String // Значение фильтра
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([filterType])
  @@index([timestamp])
}

// Ошибки на клиенте — отслеживание JavaScript ошибок
model ClientError {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation("ClientErrors", fields: [userId], references: [id], onDelete: SetNull)
  message   String
  stack     String?
  page      String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([timestamp])
}

// Функции приложения — какие функции пользователи используют/не используют
model FeatureUsage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("FeatureUsages", fields: [userId], references: [id], onDelete: Cascade)
  feature   String   // notifications, reviews, sports, referrals, etc.
  action    String   // enabled, disabled, used
  value     String?  // Значение (e.g., сколько друзей пригласили)
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([feature])
  @@index([timestamp])
}

// Performance метрики — загрузка страниц
model PerformanceMetric {
  id               Int      @id @default(autoincrement())
  userId           Int?
  user             User?    @relation("PerformanceMetrics", fields: [userId], references: [id], onDelete: SetNull)
  page             String
  pageLoadTime     Int?     // мс
  dnsTime          Int?     // мс
  tcpTime          Int?     // мс
  ttfb             Int?     // Time to First Byte (мс)
  fcpTime          Int?     // First Contentful Paint (мс)
  lcpTime          Int?     // Largest Contentful Paint (мс)
  fid              Int?     // First Input Delay (мс)
  cls              Float?   // Cumulative Layout Shift
  memoryUsed       Int?     // Используемая память (MB)
  timestamp        DateTime @default(now())

  @@index([userId])
  @@index([page])
  @@index([timestamp])
}

// Взаимодействие с контентом
model ContentInteraction {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation("ContentInteractions", fields: [userId], references: [id], onDelete: Cascade)
  contentType String  // lesson, teacher, sport_section, feedback_item, etc.
  contentId  Int
  action     String   // view, favorite, share, report, etc.
  duration   Int?     // Время взаимодействия (секунды)
  timestamp  DateTime @default(now())

  @@index([userId])
  @@index([contentType])
  @@index([timestamp])
}

// Покупки/подписки (для будущих платных функций)
model Subscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("Subscriptions", fields: [userId], references: [id], onDelete: Cascade)
  type      String   // premium, vip, etc.
  status    String   @default("active") // active, cancelled, expired
  amount    Float?   // Сумма оплаты
  currency  String?  // RUB, USD
  startedAt DateTime @default(now())
  expiresAt DateTime?
  cancelledAt DateTime?

  @@index([userId])
  @@index([status])
}

// Рекомендации/sugestions для статистики
model Recommendation {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("Recommendations", fields: [userId], references: [id], onDelete: Cascade)
  type         String   // schedule_tip, teacher_suggestion, sport_suggestion, etc.
  recommendation String  // Текст рекомендации
  shown        Boolean  @default(true)
  clicked      Boolean  @default(false)
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([timestamp])
}

// Отслеживание кликов на кнопки (детальная статистика)
model ButtonClick {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation("ButtonClicks", fields: [userId], references: [id], onDelete: Cascade)
  buttonName   String   // profile_btn, today_btn, tomorrow_btn, feedback_btn, etc.
  buttonText   String?  // Отображаемый текст кнопки
  buttonGroup  String   // Группа: navigation, schedule, admin, profile, sports, feedback, etc.
  page         String?  // Страница где находилась кнопка
  sessionToken String?  // Сессия пользователя
  timestamp    DateTime @default(now())

  @@index([userId])
  @@index([buttonName])
  @@index([buttonGroup])
  @@index([timestamp])
  @@index([page])
}

// Ежедневные/еженедельные/ежемесячные метрики пользователя (кэш)
model UserMetricsSnapshot {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation("MetricsSnapshots", fields: [userId], references: [id], onDelete: Cascade)
  period          String   @default("daily") // daily, weekly, monthly
  date            DateTime // Дата снимка
  sessionCount    Int      @default(0)
  totalDuration   Int      @default(0) // Секунды
  pageViews       Int      @default(0)
  events          Int      @default(0)
  lastActive      DateTime?
  createdAt       DateTime @default(now())

  @@unique([userId, period, date])
  @@index([date])
}

// Глобальные метрики приложения (статистика по всему приложению)
model AppMetric {
  id            Int      @id @default(autoincrement())
  metricType    String   // dau, mau, new_users, active_sessions, etc.
  metricValue   Int
  metricDate    DateTime
  metadata      String?  // JSON для дополнительных данных
  createdAt     DateTime @default(now())

  @@unique([metricType, metricDate])
  @@index([metricType])
  @@index([metricDate])
}

// ===== Глобальные настройки (инвайт-система и другое) =====
model AdminSettings {
  id                    Int @id @default(autoincrement())
  inviteCooldownHours   Int @default(24) // N часов между создением кодов
  maxActiveCodesPerUser Int @default(5) // Макс неиспользованных кодов

  @@unique([id]) // Гарантирует что записей в таблице максимум одна
}
